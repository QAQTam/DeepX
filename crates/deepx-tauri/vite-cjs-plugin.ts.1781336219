// Vite plugin: patch CJS modules that lack ESM default export
// For Vite 8 + rolldown which have stricter CJS→ESM interop

import { createRequire } from "module";

const CJS_PACKAGES = [
  "debug",
  "extend",
  "style-to-object",
  "property-information",
  "space-separated-tokens",
  "comma-separated-tokens",
  "decode-named-character-reference",
  "character-entities",
  "bail",
  "is-plain-obj",
  "trough",
];

export function cjsShimPlugin() {
  const virtualIdPrefix = "virtual:cjs-shim:";
  const resolvedPrefix = "\0" + virtualIdPrefix;

  return {
    name: "cjs-shim",
    enforce: "pre" as const,
    resolveId(id: string) {
      if (CJS_PACKAGES.includes(id)) {
        return resolvedPrefix + id;
      }
    },
    load(id: string) {
      if (id.startsWith(resolvedPrefix)) {
        const pkgName = id.slice(resolvedPrefix.length);
        try {
          const require = createRequire(import.meta.url);
          const mod = require(pkgName);
          return `const mod = ${JSON.stringify(mod)};
export default mod;
export const { ${Object.keys(mod).filter(k => k !== 'default' && !k.startsWith('_')).join(", ")} } = mod;`;
        } catch {
          return `export default {};`;
        }
      }
    },
  };
}
